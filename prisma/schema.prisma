generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  prenom          String
  nom             String
  email           String    @unique
  passwordHash    String
  roleId          String
  active          Boolean   @default(true)
  accessOverrides Json?
  createdAt       DateTime  @default(now())
  lastLogin       DateTime?
  avatar          String?

  tasks               Task[]
  sentMessages        InternalMessage[]  @relation("MessageSender")
  channelMemberships  ChannelMember[]
  notifications       Notification[]
  teamMemberships     TeamMember[]

  @@map("users")
}

// ── Équipes ───────────────────────────────────────────────────
model Team {
  id      String       @id @default(cuid())
  name    String       // "Gestion", "Transaction", "Syndic", "Direction"
  color   String       @default("#B8966A")
  icon    String?
  order   Int          @default(0)
  members TeamMember[]
  families TaskFamily[]

  @@map("teams")
}

model TeamMember {
  teamId String
  userId String
  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@map("team_members")
}

// ── Tâches hiérarchiques ─────────────────────────────────────

model TaskFamily {
  id          String      @id @default(cuid())
  name        String
  description String?
  color       String      @default("#B8966A")
  icon        String?
  order       Int         @default(0)
  teamId      String?     // null = visible par tous
  createdAt   DateTime    @default(now())
  team        Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  groups      TaskGroup[]
  tasks       Task[]

  @@map("task_families")
}

model TaskGroup {
  id          String     @id @default(cuid())
  familyId    String
  name        String
  description String?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  family      TaskFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@map("task_groups")
}

model Task {
  id           String      @id @default(cuid())
  title        String
  description  String?
  status       String      @default("todo")
  priority     String      @default("moyenne")
  assigneeId   String?
  assignee     User?       @relation(fields: [assigneeId], references: [id])
  assigneeName String?
  familyId     String?
  family       TaskFamily? @relation(fields: [familyId], references: [id], onDelete: SetNull)
  groupId      String?
  group        TaskGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  dueDate      DateTime?
  tags         String[]
  project      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("tasks")
}

// ── Mémoire de classification des mails ──────────────────────
model MailLabelMemory {
  id           String   @id @default(cuid())
  fromEmail    String   @unique
  labelIds     String[]
  assignedToId String?
  note         String?  // contexte mémorisé (ex: "propriétaire immeuble X")
  updatedAt    DateTime @updatedAt

  @@map("mail_label_memory")
}

// ── Événements agenda ────────────────────────────────────────

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  location    String?
  start       DateTime
  end         DateTime
  allDay      Boolean  @default(false)
  color       String   @default("#B8966A")
  type        String   @default("autre")
  createdBy   String
  attendees   Json?    // [{type:"user"|"contact", id?, name, email}]
  googleId    String?  // ID Google Calendar si synchronisé
  notifSent   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("calendar_events")
}

// ── Messagerie interne ───────────────────────────────────────

model Channel {
  id          String          @id @default(cuid())
  name        String
  description String?
  isDirect    Boolean         @default(false)
  createdBy   String
  createdAt   DateTime        @default(now())
  members     ChannelMember[]
  messages    InternalMessage[]

  @@map("channels")
}

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  joinedAt  DateTime @default(now())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@map("channel_members")
}

model InternalMessage {
  id        String   @id @default(cuid())
  channelId String
  senderId  String
  content   String
  createdAt DateTime @default(now())
  readBy    String[]

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender  User    @relation("MessageSender", fields: [senderId], references: [id])

  @@map("internal_messages")
}

// ── Notifications ────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ── Paramètres admin ─────────────────────────────────────────

model Setting {
  key       String @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ── Annonces ─────────────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  version   String?
  createdAt DateTime @default(now())

  @@map("announcements")
}

// ── Comptes email d'agence (partagés) ────────────────────────

model MailAccountConfig {
  id            String   @id @default(cuid())
  label         String
  email         String
  name          String
  protocol      String   @default("imap")
  host          String
  port          Int      @default(993)
  ssl           Boolean  @default(true)
  username      String
  password      String
  smtpHost      String   @default("")
  smtpPort      Int      @default(587)
  smtpSsl       Boolean  @default(true)
  color         String   @default("#B8966A")
  active        Boolean  @default(true)
  isShared      Boolean  @default(false)
  sharedUserIds String[] @default([])
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("mail_account_configs")
}

// ── Messagerie email persistée ────────────────────────────────

model EmailMessage {
  id          String   @id @default(cuid())
  uid         String
  messageId   String?
  folder      String   @default("INBOX")
  accountId   String
  fromEmail   String
  fromName    String?
  toEmail     String
  subject     String
  bodyText    String?
  bodyHtml    String?
  date        DateTime
  read        Boolean  @default(false)
  starred     Boolean  @default(false)
  attachments Json?
  threadId    String?
  labels      String[] @default([])
  senderType  String?  // "user"|"owner"|"tenant"|"unknown"
  senderId    String?
  createdAt   DateTime @default(now())

  @@unique([uid, accountId, folder])
  @@map("email_messages")
}

// ── Fournisseurs ─────────────────────────────────────────────

model Supplier {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("autre")   // plomberie, electricite, menuiserie, maconnerie, peinture, autre
  contact   String?
  phone     String?
  email     String?
  address   String?
  siret     String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    ServiceOrder[]

  @@map("suppliers")
}

// ── Ordres de service ────────────────────────────────────────

model ServiceOrder {
  id          String    @id @default(cuid())
  ref         String    @unique   // ODS-2026-001
  taskId      String?
  supplierId  String
  title       String
  description String?
  address     String?
  deadline    DateTime?
  amount      Float?
  status      String    @default("brouillon")  // brouillon, envoyé, accepté, en_cours, terminé, annulé
  notes       String?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  supplier    Supplier  @relation(fields: [supplierId], references: [id])

  @@map("service_orders")
}

// ── Gestion locative ─────────────────────────────────────────

model Owner {
  id          String   @id @default(cuid())
  prenom      String
  nom         String
  ownerType   String   @default("individual")   // individual, sci, company
  email       String?
  phone       String?
  mobile      String?
  companyName String?
  siret       String?
  address     String?
  iban        String?
  bic         String?
  bankName    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lots        Lot[]

  @@map("owners")
}

model Tenant {
  id               String   @id @default(cuid())
  prenom           String
  nom              String
  email            String?
  phone            String?
  mobile           String?
  address          String?
  birthDate        String?
  profession       String?
  emergencyName    String?
  emergencyPhone   String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  baux             BailTenant[]

  @@map("tenants")
}

// ── Biens immobiliers ────────────────────────────────────────

model Lot {
  id          String   @id @default(cuid())
  reference   String   @unique
  label       String?
  address     String
  lotType     String   @default("apartment")  // apartment, house, commercial, parking, storage
  surface     Float?
  rooms       Int?
  floor       Int?
  status      String   @default("vacant")     // vacant, occupied, under_work
  ownerId     String?
  owner       Owner?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  baux        Bail[]

  @@map("lots")
}

// ── Baux (contrats de location) ──────────────────────────────

model Bail {
  id          String    @id @default(cuid())
  reference   String    @unique
  lotId       String
  lot         Lot       @relation(fields: [lotId], references: [id], onDelete: Cascade)
  leaseType   String    @default("residential")  // residential, commercial, mixed
  startDate   DateTime
  endDate     DateTime?
  monthlyRent Float
  charges     Float     @default(0)
  deposit     Float?
  renewalType String    @default("tacit")        // tacit, fixed
  status      String    @default("active")       // active, terminated, suspended, pending
  signedDate  DateTime?
  notes       String?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenants       BailTenant[]
  appels        AppelLoyer[]
  encaissements Encaissement[]
  depot         DepotGarantie?

  @@map("baux")
}

model BailTenant {
  id       String @id @default(cuid())
  bailId   String
  tenantId String
  bail     Bail   @relation(fields: [bailId], references: [id], onDelete: Cascade)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([bailId, tenantId])
  @@map("bail_tenants")
}

// ── Notes personnelles ────────────────────────────────────────

model PersonalNote {
  id        String   @id @default(cuid())
  userId    String
  content   String
  color     String   @default("#FFFBEB")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("personal_notes")
}

// ── Appels téléphoniques ─────────────────────────────────────

model PhoneCall {
  id          String   @id @default(cuid())
  userId      String
  contact     String
  phone       String?
  direction   String   @default("inbound")   // inbound, outbound
  status      String   @default("to_call")   // to_call, called, missed, callback
  subject     String?
  notes       String?
  calledAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("phone_calls")
}

// ── Comptabilité ──────────────────────────────────────────────

model AppelLoyer {
  id          String   @id @default(cuid())
  reference   String   @unique
  bailId      String
  bail        Bail     @relation(fields: [bailId], references: [id], onDelete: Cascade)
  periode     String   // "2025-01" (YYYY-MM)
  montantHC   Float
  charges     Float    @default(0)
  totalCC     Float
  echeance    DateTime
  status      String   @default("emis")  // emis, partiel, regle, impaye
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  encaissements Encaissement[]

  @@map("appels_loyer")
}

model Encaissement {
  id           String      @id @default(cuid())
  reference    String      @unique
  appelId      String?
  appel        AppelLoyer? @relation(fields: [appelId], references: [id], onDelete: SetNull)
  bailId       String
  bail         Bail        @relation(fields: [bailId], references: [id], onDelete: Cascade)
  montant      Float
  dateReglement DateTime
  modePaiement String      @default("virement")  // virement, cheque, especes, prelevement
  reference_paiement String?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("encaissements")
}

model DepotGarantie {
  id           String   @id @default(cuid())
  bailId       String   @unique
  bail         Bail     @relation(fields: [bailId], references: [id], onDelete: Cascade)
  montant      Float
  dateRecep    DateTime
  dateRestitution DateTime?
  montantRestitue Float?
  status       String   @default("conserve")  // conserve, restitue, partiel
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("depots_garantie")
}

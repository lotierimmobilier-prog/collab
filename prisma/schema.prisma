generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  prenom          String
  nom             String
  email           String    @unique
  passwordHash    String
  roleId          String
  active          Boolean   @default(true)
  isEmployee      Boolean   @default(false) // salarié de l'agence (décompte d'heures, congés)
  accessOverrides Json?
  gedAccess       String?   // null = défaut selon rôle | complet | restreint | aucun
  phone           String?
  createdAt       DateTime  @default(now())
  lastLogin       DateTime?
  avatar          String?

  parrainId       String?   // parrain (formation par parrainage)
  parrain         User?     @relation("Mentorship", fields: [parrainId], references: [id], onDelete: SetNull)
  filleuls        User[]    @relation("Mentorship")

  tasks               Task[]
  sentMessages        InternalMessage[]  @relation("MessageSender")
  channelMemberships  ChannelMember[]
  notifications       Notification[]
  teamMemberships     TeamMember[]

  @@map("users")
}

// ── Équipes ───────────────────────────────────────────────────
model Team {
  id      String       @id @default(cuid())
  name    String       // "Gestion", "Transaction", "Syndic", "Direction"
  color   String       @default("#B8966A")
  icon    String?
  order   Int          @default(0)
  members TeamMember[]
  families TaskFamily[]

  @@map("teams")
}

model TeamMember {
  teamId String
  userId String
  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@map("team_members")
}

// ── Tâches hiérarchiques ─────────────────────────────────────

model TaskFamily {
  id          String      @id @default(cuid())
  name        String
  description String?
  color       String      @default("#B8966A")
  icon        String?
  order       Int         @default(0)
  teamId      String?     // null = visible par tous
  createdAt   DateTime    @default(now())
  team        Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  groups      TaskGroup[]
  tasks       Task[]

  @@map("task_families")
}

model TaskGroup {
  id          String     @id @default(cuid())
  familyId    String
  name        String
  description String?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  family      TaskFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@map("task_groups")
}

model Task {
  id           String      @id @default(cuid())
  title        String
  description  String?
  status       String      @default("todo")
  priority     String      @default("moyenne")
  assigneeId   String?
  assignee     User?       @relation(fields: [assigneeId], references: [id])
  assigneeName String?
  familyId     String?
  family       TaskFamily? @relation(fields: [familyId], references: [id], onDelete: SetNull)
  groupId      String?
  group        TaskGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  dueDate      DateTime?
  tags         String[]
  project      String?
  recurrence   String?    // null | 7d | 15d | 30d | trimestre | semestre | annee
  createdById  String?
  completedAt   DateTime?
  completedById String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([assigneeId])
  @@index([createdById])
  @@map("tasks")
}

// ── Mémoire de classification des mails ──────────────────────
model MailLabelMemory {
  id           String   @id @default(cuid())
  fromEmail    String   @unique
  labelIds     String[]
  assignedToId String?
  note         String?  // contexte mémorisé (ex: "propriétaire immeuble X")
  updatedAt    DateTime @updatedAt

  @@map("mail_label_memory")
}

// ── Événements agenda ────────────────────────────────────────

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  location    String?
  start       DateTime
  end         DateTime
  allDay      Boolean  @default(false)
  color       String   @default("#B8966A")
  type        String   @default("autre")
  createdBy   String
  attendees   Json?    // [{type:"user"|"contact", id?, name, email}]
  googleId    String?  // ID Google Calendar si synchronisé
  notifSent   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("calendar_events")
}

// ── Messagerie interne ───────────────────────────────────────

model Channel {
  id          String          @id @default(cuid())
  name        String
  description String?
  isDirect    Boolean         @default(false)
  createdBy   String
  createdAt   DateTime        @default(now())
  members     ChannelMember[]
  messages    InternalMessage[]

  @@map("channels")
}

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  joinedAt  DateTime @default(now())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@map("channel_members")
}

model InternalMessage {
  id          String   @id @default(cuid())
  channelId   String
  senderId    String
  content     String
  attachments Json?    // pièces jointes (≤20 Mo), purgées après 30 jours
  createdAt   DateTime @default(now())
  readBy      String[]

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender  User    @relation("MessageSender", fields: [senderId], references: [id])

  @@map("internal_messages")
}

// ── Notifications ────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ── Base de connaissance Auguste ──────────────────────────────

model KnowledgeDoc {
  id          String   @id @default(cuid())
  title       String
  category    String   @default("general")  // general, juridique, comptabilite, procedure, baux, autre
  content     String   // texte extrait du PDF ou texte brut
  fileName    String?
  fileSize    Int?
  active      Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("knowledge_docs")
}

// ── Paramètres admin ─────────────────────────────────────────

model Setting {
  key       String @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ── Journal des demandes à Auguste (audit admin) ─────────────
model AugusteLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  question  String
  reply     String?
  tools     String[] @default([])
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@map("auguste_logs")
}

// ── Annonces ─────────────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  version   String?
  createdAt DateTime @default(now())

  @@map("announcements")
}

// ── Comptes email d'agence (partagés) ────────────────────────

model MailAccountConfig {
  id            String   @id @default(cuid())
  label         String
  email         String
  name          String
  protocol      String   @default("imap")
  host          String
  port          Int      @default(993)
  ssl           Boolean  @default(true)
  username      String
  password      String
  smtpHost      String   @default("")
  smtpPort      Int      @default(587)
  smtpSsl       Boolean  @default(true)
  color         String   @default("#B8966A")
  active        Boolean  @default(true)
  isShared      Boolean  @default(false)
  sharedUserIds String[] @default([])
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("mail_account_configs")
}

// ── Messagerie email persistée ────────────────────────────────

model EmailMessage {
  id          String   @id @default(cuid())
  uid         String
  messageId   String?
  folder      String   @default("INBOX")
  accountId   String
  fromEmail   String
  fromName    String?
  toEmail     String
  subject     String
  bodyText    String?
  bodyHtml    String?
  date        DateTime
  read        Boolean  @default(false)
  starred     Boolean  @default(false)
  attachments Json?
  threadId    String?
  labels      String[] @default([])
  senderType  String?  // "user"|"owner"|"tenant"|"unknown"
  senderId    String?
  ownerId     String?  // utilisateur agence ayant synchronisé/envoyé ce message (cloisonnement)
  createdAt   DateTime @default(now())

  @@unique([uid, accountId, folder])
  @@index([ownerId])
  @@map("email_messages")
}

// ── Fournisseurs ─────────────────────────────────────────────

model Supplier {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("autre")   // plomberie, electricite, menuiserie, maconnerie, peinture, autre
  contact   String?
  phone     String?
  email     String?
  address   String?
  siret     String?
  notes     String?
  active    Boolean  @default(true)
  // ── Rapprochement ICS (import de l'export Fournisseurs) ──
  icsNum    String?  @unique             // N° fournisseur ICS (ex. 40129695)
  metier    String?                      // libellé métier ICS (plus précis que `type`)
  iban      String?
  modeReglement String?                  // Virement | Chèque | …
  scope     String   @default("gestion") // gestion | syndic
  contactId String?                      // fiche annuaire liée
  // ── Conformité assurance (décennale / RC pro) ──
  insuranceType   String?               // decennale | rcpro | both | autre
  insurer         String?               // assureur
  insurancePolicy String?               // n° de police
  insuranceExpiry DateTime?             // fin de validité de l'attestation
  insuranceDoc    Json?                 // attestation : {name,mime,size,data}
  // ── Attestation de vigilance URSSAF ──
  urssafExpiry    DateTime?             // fin de validité de l'attestation URSSAF
  urssafDoc       Json?                 // attestation URSSAF : {name,mime,size,data}
  // ── Espace fournisseur (dépôt des justificatifs par lien) ──
  portalToken     String?  @unique      // jeton du lien espace fournisseur
  lastConfReminderAt DateTime?          // dernière relance « documents à jour »
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    ServiceOrder[]

  @@index([scope])
  @@map("suppliers")
}

// ── Ordres de service ────────────────────────────────────────

model ServiceOrder {
  id          String    @id @default(cuid())
  ref         String    @unique   // ODS-2026-001
  taskId      String?
  supplierId  String
  title       String
  description String?
  address     String?
  deadline    DateTime?
  amount      Float?
  status      String    @default("brouillon")  // brouillon, envoyé, accepté, en_cours, terminé, annulé
  notes       String?
  createdBy   String
  // ── Détail d'intervention ──
  interventionType String?               // Plomberie, Serrurerie, Fuite, Électricité…
  onSiteName       String?               // contact sur place (nom)
  onSitePhone      String?
  onSiteRole       String?               // locataire | coproprietaire | proprietaire | gardien | autre
  keyAtAgency      Boolean  @default(false) // si pas loué : clé à l'agence
  accessInfo       String?               // digicode, étage, bâtiment, instructions
  urgency          String?               // normal | urgent
  quoteRequired    Boolean  @default(false) // devis obligatoire avant intervention
  agentName        String?               // agent référent (coordonnées agence)
  agentPhone       String?
  // ── Pièces jointes (photos du sinistre, plans…) : [{id,name,mime,size,data}] ──
  attachments Json?
  // ── Espace d'échange fournisseur (portail externe) ──
  supplierToken String? @unique          // jeton du lien fournisseur
  messages      Json?                    // fil : [{id,author,name,body,at}]
  supplierFiles Json?                    // dépôts : [{id,kind,name,mime,size,data,at,by}]
  // ── Suivi d'envoi ──
  sentAt      DateTime?
  sentTo      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  supplier    Supplier  @relation(fields: [supplierId], references: [id])

  @@map("service_orders")
}

/// Demande d'assistance locataire/copropriétaire : lien envoyé par l'agence,
/// le déclarant décrit le sinistre et joint des photos depuis son téléphone.
/// Sert de point d'entrée à un ordre de service.
model AssistanceRequest {
  id           String   @id @default(cuid())
  token        String   @unique          // jeton du lien public
  role         String   @default("locataire") // locataire | coproprietaire
  contactName  String?
  contactPhone String?
  contactEmail String?
  address      String?
  description  String?
  photos       Json?                      // [{id,name,mime,size,data}]
  status       String   @default("nouvelle") // nouvelle | soumise | ods_cree | cloturee
  odsId        String?
  createdById  String?
  submittedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@map("assistance_requests")
}

// ── Gestion locative ─────────────────────────────────────────

model Owner {
  id          String   @id @default(cuid())
  prenom      String
  nom         String
  ownerType   String   @default("individual")   // individual, sci, company
  email       String?
  phone       String?
  mobile      String?
  companyName String?
  siret       String?
  address     String?
  iban        String?
  bic         String?
  bankName    String?
  notes       String?
  icsMandat   String?           // mandat ICS représentatif (informatif)
  icsKey      String?  @unique   // clé de regroupement (nom normalisé) : un compte par propriétaire
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lots        Lot[]

  @@map("owners")
}

model Tenant {
  id               String   @id @default(cuid())
  prenom           String
  nom              String
  email            String?
  phone            String?
  mobile           String?
  address          String?
  birthDate        String?
  profession       String?
  emergencyName    String?
  emergencyPhone   String?
  notes            String?
  icsBail          String?  @unique   // référence ICS (idBail) pour la synchro
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  baux             BailTenant[]

  @@map("tenants")
}

// ── Biens immobiliers ────────────────────────────────────────

model Lot {
  id          String   @id @default(cuid())
  reference   String   @unique
  label       String?
  address     String
  lotType     String   @default("apartment")  // apartment, house, commercial, parking, storage
  surface     Float?
  rooms       Int?
  floor       Int?
  status      String   @default("vacant")     // vacant, occupied, under_work
  ownerId     String?
  owner       Owner?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  notes       String?
  icsLot      String?  @unique   // référence ICS (idLot) pour la synchro
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  baux        Bail[]

  @@map("lots")
}

// ── Baux (contrats de location) ──────────────────────────────

model Bail {
  id          String    @id @default(cuid())
  reference   String    @unique
  lotId       String
  lot         Lot       @relation(fields: [lotId], references: [id], onDelete: Cascade)
  leaseType   String    @default("residential")  // residential, commercial, mixed
  startDate   DateTime
  endDate     DateTime?
  monthlyRent Float
  charges     Float     @default(0)
  deposit     Float?
  renewalType String    @default("tacit")        // tacit, fixed
  status      String    @default("active")       // active, terminated, suspended, pending
  signedDate  DateTime?
  notes       String?
  icsBail     String?   @unique   // référence ICS (idBail) pour la synchro
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenants       BailTenant[]
  appels        AppelLoyer[]
  encaissements Encaissement[]
  depot         DepotGarantie?

  @@map("baux")
}

model BailTenant {
  id       String @id @default(cuid())
  bailId   String
  tenantId String
  bail     Bail   @relation(fields: [bailId], references: [id], onDelete: Cascade)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([bailId, tenantId])
  @@map("bail_tenants")
}

// ── Notes personnelles ────────────────────────────────────────

model PersonalNote {
  id        String   @id @default(cuid())
  userId    String
  content   String
  color     String   @default("#FFFBEB")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("personal_notes")
}

// ── Appels téléphoniques ─────────────────────────────────────

model PhoneCall {
  id          String   @id @default(cuid())
  userId      String
  contact     String
  phone       String?
  direction   String   @default("inbound")   // inbound, outbound
  status      String   @default("to_call")   // to_call, called, missed, callback
  subject     String?
  notes       String?
  calledAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("phone_calls")
}

// ── Comptabilité ──────────────────────────────────────────────

model AppelLoyer {
  id          String   @id @default(cuid())
  reference   String   @unique
  bailId      String
  bail        Bail     @relation(fields: [bailId], references: [id], onDelete: Cascade)
  periode     String   // "2025-01" (YYYY-MM)
  montantHC   Float
  charges     Float    @default(0)
  totalCC     Float
  echeance    DateTime
  status      String   @default("emis")  // emis, partiel, regle, impaye
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  encaissements Encaissement[]

  @@map("appels_loyer")
}

model Encaissement {
  id           String      @id @default(cuid())
  reference    String      @unique
  appelId      String?
  appel        AppelLoyer? @relation(fields: [appelId], references: [id], onDelete: SetNull)
  bailId       String
  bail         Bail        @relation(fields: [bailId], references: [id], onDelete: Cascade)
  montant      Float
  dateReglement DateTime
  modePaiement String      @default("virement")  // virement, cheque, especes, prelevement
  reference_paiement String?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("encaissements")
}

model DepotGarantie {
  id           String   @id @default(cuid())
  bailId       String   @unique
  bail         Bail     @relation(fields: [bailId], references: [id], onDelete: Cascade)
  montant      Float
  dateRecep    DateTime
  dateRestitution DateTime?
  montantRestitue Float?
  status       String   @default("conserve")  // conserve, restitue, partiel
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("depots_garantie")
}

/// Annuaire unifié : tout contact (interne ou externe) avec son type/label.
/// Carnet d'adresses central, relié aux mails / tâches / agenda.
model Contact {
  id            String   @id @default(cuid())
  type          String   @default("autre") // fournisseur|proprietaire|locataire|direction|commercial|tutelle|autre
  prenom        String?
  nom           String?
  raisonSociale String?
  email         String?
  phone         String?
  note          String?
  /// Lien optionnel vers l'entité métier d'origine
  sourceType    String?  // owner|tenant|supplier|user
  sourceId      String?
  /// Rapprochement ICS (renseigné à l'import de l'export Locataires)
  icsType       String?  // locataire|proprietaire|coproprietaire
  icsRef        String?  // idBail (locataire) ou idMandat (propriétaire)
  icsIdLot      String?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([email])
  @@index([type])
  @@map("contacts")
}

/// Performances commerciales : chaque entrée = une opération réalisée par un
/// agent (vente, mandat de vente, mandat de location, mise en location).
/// Saisie par l'administrateur ; alimente le classement du trimestre affiché
/// sur le tableau de bord des commerciaux.
model PerformanceEntry {
  id          String   @id @default(cuid())
  userId      String   // agent crédité de l'opération
  type        String   // vente | mandat_vente | mandat_loc | mise_en_loc
  label       String?  // bien / adresse / référence (optionnel)
  amount      Float?   // montant ou honoraires (optionnel)
  date        DateTime // date de l'opération (détermine le trimestre)
  createdById String?  // admin qui a saisi
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([date])
  @@map("performance_entries")
}

// ── Gestion d'entreprise (Direction) ─────────────────────────

/// Flotte automobile de l'entreprise.
model Vehicle {
  id             String    @id @default(cuid())
  label          String    // marque + modèle, ex. « Peugeot 208 »
  immatriculation String?
  holdType       String    @default("propriete") // propriete | leasing | location
  assignedToId   String?
  assignedName   String?
  insurer        String?
  startDate      DateTime?
  endDate        DateTime? // fin de leasing / location
  controleTechnique DateTime?
  monthlyCost    Float?
  currentKm      Int?      // dernier kilométrage connu
  documents      Json?     // { assurance, carteGrise, permis } : fichiers base64
  kmReadings     Json?     // relevés [{ date, km }]
  sinistres      Json?     // [{ id, date, type, declared, description }]
  note           String?
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("vehicles")
}

/// Locaux loués par l'entreprise (baux commerciaux, bureaux, parkings…).
model Premise {
  id          String    @id @default(cuid())
  label       String    // nom / désignation du local
  address     String?
  bailleur    String?
  insurer     String?   // assureur du local
  startDate   DateTime?
  endDate     DateTime?
  rentMonthly Float?
  charges     Float?
  documents   Json?     // documents (assurance, bail, diagnostics…) : fichiers base64
  sinistres   Json?     // [{ id, date, type, declared, description }]
  controls    Json?     // contrôles de sécurité [{ id, type, date, nextDate, status, note }]
  note        String?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("premises")
}

/// Cartes professionnelles (agents commerciaux et direction).
model ProCard {
  id          String    @id @default(cuid())
  userId      String?
  holderName  String    // titulaire de la carte
  cardNumber  String?
  cardType    String?   // transaction | gestion | both
  issuedBy    String?   // CCI émettrice
  startDate   DateTime?
  expiryDate  DateTime?
  note        String?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("pro_cards")
}

/// Contrats d'assurance de l'entreprise.
model InsurancePolicy {
  id            String    @id @default(cuid())
  type          String    @default("rc") // rc | rcpro | bureaux | autre
  insurer       String?
  policyNumber  String?
  startDate     DateTime?
  endDate       DateTime?
  premiumAmount Float?
  note          String?
  createdById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("insurance_policies")
}

// ── Comptabilité : banque & trésorerie ───────────────────────

/// Compte de trésorerie. Séparation stricte gestion / syndic (fonds mandants).
model BankAccount {
  id             String   @id @default(cuid())
  name           String
  kind           String   @default("agence") // gestion | syndic | agence
  openingBalance Float    @default(0)
  threshold      Float?   // seuil d'alerte (plancher)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions BankTransaction[]

  @@map("bank_accounts")
}

/// Opération d'un relevé bancaire. amount > 0 = crédit, < 0 = débit.
model BankTransaction {
  id          String   @id @default(cuid())
  accountId   String
  date        DateTime
  label       String
  amount      Float
  service     String?  // vente | gestion | syndic | agence
  nature      String?
  recurring   Boolean  @default(false)
  source      String   @default("manual") // pdf | ofx | qif | manual
  importId    String?
  createdById String?
  createdAt   DateTime @default(now())

  account BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([date])
  @@index([service])
  @@map("bank_transactions")
}

/// Mémoire d'auto-apprentissage : libellé normalisé → service habituel.
model TxnMemory {
  id          String   @id @default(cuid())
  pattern     String   @unique
  service     String?
  recurring   Boolean  @default(false)
  occurrences Int      @default(1)
  lastDate    DateTime?
  updatedAt   DateTime @updatedAt

  @@map("txn_memory")
}

/// Journal d'activité : connexions, déconnexions et actions des utilisateurs.
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  userName  String?
  kind      String   @default("action") // login | logout | action
  label     String?
  path      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ── Formation par parrainage ─────────────────────────────────

model TrainingModule {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  competences TrainingCompetence[]

  @@map("training_modules")
}

model TrainingCompetence {
  id          String   @id @default(cuid())
  moduleId    String
  module      TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  validations CompetenceValidation[]
  questions   TrainingQuestion[]

  @@index([moduleId])
  @@map("training_competences")
}

/// Question de contrôle des connaissances (QCM) rattachée à une compétence.
model TrainingQuestion {
  id           String   @id @default(cuid())
  competenceId String
  competence   TrainingCompetence @relation(fields: [competenceId], references: [id], onDelete: Cascade)
  prompt       String
  choices      Json     // ["réponse A", "réponse B", …]
  correctIndex Int      @default(0)
  explanation  String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([competenceId])
  @@map("training_questions")
}

/// Avancement d'un filleul sur une compétence : dates réalisées + double
/// validation (parrain + filleul). Terminée quand les deux ont validé.
model CompetenceValidation {
  id                 String   @id @default(cuid())
  competenceId       String
  competence         TrainingCompetence @relation(fields: [competenceId], references: [id], onDelete: Cascade)
  filleulId          String
  dates              Json?    // jours réalisés : ["2026-06-27", …]
  parrainValidated   Boolean  @default(false)
  parrainValidatedAt DateTime?
  parrainComment     String?
  filleulValidated   Boolean  @default(false)
  filleulValidatedAt DateTime?
  filleulComment     String?
  quiz               Json?    // réponses du filleul au QCM : { "<questionId>": <indexChoisi> }
  updatedAt          DateTime @updatedAt @default(now())

  @@unique([competenceId, filleulId])
  @@index([filleulId])
  @@map("competence_validations")
}

/// Mémoire d'Auguste : termes techniques appris au fil des demandes (glossaire agence).
model AugusteTerm {
  id          String   @id @default(cuid())
  term        String   @unique
  definition  String?
  occurrences Int      @default(1)
  lastUsed    DateTime @default(now())
  createdAt   DateTime @default(now())

  @@map("auguste_terms")
}

/// Temps de présence quotidien par utilisateur (secondes actives).
// Connexion Google Agenda permanente (OAuth serveur, hors-ligne).
// Le refresh_token est stocké CHIFFRÉ ; l'access_token est mis en cache et
// rafraîchi automatiquement → l'agenda reste affiché sans reconnexion.
model GoogleCalendarAccount {
  id           String    @id @default(cuid())
  userId       String    @unique
  googleEmail  String?
  refreshToken String                // chiffré (AES-256-GCM)
  accessToken  String?               // cache chiffré
  accessExpiry DateTime?
  selected     String[]              // ids d'agendas affichés
  calendars    Json?                 // cache de la liste des agendas
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("google_calendar_accounts")
}

model UserPresence {
  id       String   @id @default(cuid())
  userId   String
  userName String?
  day      String   // AAAA-MM-JJ
  seconds  Int      @default(0)
  lastSeen DateTime @default(now())

  @@unique([userId, day])
  @@index([day])
  @@map("user_presence")
}

/// Compte rendu de réunion de direction. Pièces jointes (PDF / audio) en base64
/// dans `documents` : [{ id, name, mime, kind: "pdf"|"audio", size, data }].
model DirectionMeeting {
  id           String   @id @default(cuid())
  title        String   @default("Réunion de direction")
  date         DateTime
  participants String?
  summary      String?
  documents    Json?
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
  @@map("direction_meetings")
}

/// Connecteur ICS (MyICS / Spirit). Configuration unique (id = "default").
/// Le mot de passe est stocké chiffré (AES-256-GCM). Jamais en clair.
model IcsConfig {
  id          String    @id @default("default")
  authBaseUrl String    @default("https://auth.ics.fr/auth")
  realm       String    @default("Production")
  clientId    String    @default("myics-customer")
  portalUrl   String    @default("https://my.ics.fr")
  apiBaseUrl    String?   // base de l'API Spirit, renseignée depuis le HAR
  spiritApiBase String   @default("https://spirit6back.ics.fr/GeranceNet")
  gedApiBase    String   @default("https://ged-tomcat1.ics.fr/tomcat/Ged")
  idSociete     String   @default("54246")
  username    String?
  passwordEnc String?   // mot de passe chiffré (format iv:tag:cipher en base64)
  // Accès direct à la GED (ged-tomcat1) : login société + email + mot de passe.
  gedSociete     String?
  gedEmail       String?
  gedPasswordEnc String?
  gedCle         String?   // clé de portefeuille (mémorisée après 1er login)
  gedToken       String?   // jeton GED courant (valable ~24 h)
  gedTokenExp    DateTime?
  gedLastTestOk  Boolean   @default(false)
  gedLastError   String?
  enabled     Boolean   @default(false)
  lastTestAt  DateTime?
  lastTestOk  Boolean   @default(false)
  lastError   String?
  updatedById String?
  updatedAt   DateTime  @updatedAt @default(now())

  @@map("ics_config")
}

/// Correspondance issue de l'export ICS « Locataires » : relie un bail à son
/// locataire, son lot (bien) et son mandat (propriétaire). Sert d'index pour
/// ouvrir la GED ICS en direct, sans recherche par nom. Aucun document stocké.
model IcsTenant {
  id                 String   @id @default(cuid())
  idBail             String   @unique
  idLot              String?
  idMandat           String?
  portefeuille       String?
  civiliteLoc        String?
  nomLocataire       String?
  prenomLocataire    String?
  email              String?
  mobile             String?
  telephone          String?
  categorieBail      String?
  typeBail           String?
  dateEffet          String?
  loyer              String?
  nomImmeuble        String?
  adresseImmeuble    String?
  civiliteProprio    String?
  nomProprietaire    String?
  prenomProprietaire String?
  raw                Json?    // ligne complète de l'export (toutes les colonnes)
  updatedAt          DateTime @updatedAt @default(now())

  @@index([nomLocataire])
  @@index([nomProprietaire])
  @@map("ics_tenants")
}

/// Espace personnel — document administratif/légal de l'utilisateur
/// (assurance pro, carte pro, attestation ALUR…). Fichier en base64.
model PersonalDocument {
  id             String    @id @default(cuid())
  userId         String
  kind           String    // assurance_pro | carte_pro | alur | rib | piece_identite | autre
  label          String?
  number         String?
  issuer         String?
  issuedAt       DateTime?
  expiresAt      DateTime?
  alurHours      Int?       // heures de formation ALUR
  fileName       String?
  mime           String?
  size           Int?
  data           String?    // fichier en base64
  lastReminderAt DateTime?  // dernier rappel email d'expiration
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([userId])
  @@map("personal_documents")
}

/// Procédure d'entreprise (visible par tous, gérée par l'admin) : document
/// PDF / vidéo téléversé (base64) ou lien externe (YouTube/Vimeo).
model Procedure {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String?
  kind        String   @default("pdf") // pdf | video | link
  roles       String[] @default([])    // rôles destinataires (vide = tout le monde)
  fileName    String?
  mime        String?
  size        Int?
  data        String?  // fichier en base64 (PDF ou vidéo téléversée)
  url         String?  // lien externe (vidéo hébergée)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("procedures")
}

/// RH — demande de congé (circuit de validation par la direction).
// Dossier du salarié (côté entreprise/direction) : contrats, fiche de suivi
// annuel, RDV médecine du travail, complémentaire santé…
model EmployeeDocument {
  id          String    @id @default(cuid())
  userId      String    // salarié concerné
  category    String    // contrat | suivi_annuel | medecine_travail | mutuelle | autre
  label       String?
  issuer      String?   // organisme (mutuelle, service de santé au travail…)
  number      String?   // n° contrat / adhérent
  issuedAt    DateTime? // date du document / de la visite
  expiresAt   DateTime? // prochaine échéance (visite médicale, renouvellement…)
  fileName    String?
  mime        String?
  size        Int?
  data        String?   // fichier en base64
  note        String?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, category])
  @@map("employee_documents")
}

model LeaveRequest {
  id           String    @id @default(cuid())
  userId       String
  type         String    @default("conges_payes") // conges_payes | rtt | maladie | sans_solde | recuperation | autre
  startDate    DateTime
  endDate      DateTime
  halfDayStart Boolean   @default(false) // commence l'après-midi
  halfDayEnd   Boolean   @default(false) // finit le matin
  days         Float?    // nombre de jours décompté
  reason       String?
  status       String    @default("en_attente") // en_attente | approuve | refuse | annule
  decidedById  String?
  decidedAt    DateTime?
  decisionNote String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@map("leave_requests")
}

/// RH — relevé d'heures mensuel, signé par l'agent puis validé par la direction.
model MonthlyHours {
  id                 String    @id @default(cuid())
  userId             String
  month              String    // "2026-06"
  totalHours         Float?
  entries            Json?     // décompte quotidien : [{d, m1,m2,a1,a2,s1,s2, nuit, panier, obs}]
  note               String?
  // ── En-tête du décompte (format légal L.143-14) ──
  societe            String?
  employe            String?
  heureHebdo         Float?    // heure hebdomadaire contractuelle
  avantageNature     String?
  acompte            Float?
  acompteMode        String?   // chèque | espèce | virement
  primeMotif         String?
  primeMontant       Float?
  // ── Signature de l'agent (preuve : nom, horodatage, IP) ──
  agentSigned        Boolean   @default(false)
  agentSignedAt      DateTime?
  agentSignatureName String?
  agentSignatureIp   String?
  // ── Signature / validation direction (employeur) ──
  status             String    @default("brouillon") // brouillon | signe | valide | refuse
  validatedById      String?
  validatedAt        DateTime?
  validationNote     String?
  directionSignedAt      DateTime?
  directionSignatureName String?
  directionSignatureIp   String?
  sentToAccountantAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([userId, month])
  @@index([userId])
  @@map("monthly_hours")
}

/// Drive personnel — arborescence dossiers/fichiers par utilisateur,
/// stockée en base (fichiers en base64).
model DriveItem {
  id        String   @id @default(cuid())
  userId    String
  parentId  String?  // dossier parent (null = racine)
  kind      String   // folder | file
  name      String
  mime      String?
  size      Int?
  data      String?  // fichier en base64 (null pour un dossier)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, parentId])
  @@map("drive_items")
}
